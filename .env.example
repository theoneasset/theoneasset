# =====================================================
# 더원에셋 강남 매물 트래커 - 환경변수 템플릿
# 실제 .env.local 파일에 복사 후 값을 입력하세요
# .env.local 은 절대 Git에 커밋하지 마세요!
# =====================================================

# ── Airtable (4개 필수 키) ──────────────────────────
AIRTABLE_TOKEN=pat_xxxxxxxxxxxxxxxxxxxx
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_TABLE_ID_LISTINGS=tblXXXXXXXXXXXXXX
AIRTABLE_VIEW_ID_ACTIVE=viwXXXXXXXXXXXXXX

# ── Airtable 테이블 ID (7개 테이블) ────────────────
AIRTABLE_TABLE_BUILDINGS=tblXXXXXXXXXXXXXX
AIRTABLE_TABLE_LISTINGS=tblXXXXXXXXXXXXXX
AIRTABLE_TABLE_CLIENTS=tblXXXXXXXXXXXXXX
AIRTABLE_TABLE_PROPOSALS=tblXXXXXXXXXXXXXX
AIRTABLE_TABLE_CONTENT=tblXXXXXXXXXXXXXX
AIRTABLE_TABLE_COSTS=tblXXXXXXXXXXXXXX
AIRTABLE_TABLE_LOCK=tblXXXXXXXXXXXXXX

# ── Claude API ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
CLAUDE_COST_ALERT_USD=1.00

# ── 카카오 API ──────────────────────────────────────
KAKAO_REST_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
KAKAO_JAVASCRIPT_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 네이버 검색 API ─────────────────────────────────
NAVER_CLIENT_ID=xxxxxxxxxxxxxxxx
NAVER_CLIENT_SECRET=xxxxxxxxxxxxxxxx

# ── 솔라피 알림톡 ───────────────────────────────────
SOLAPI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SOLAPI_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SOLAPI_SENDER_PHONE=0210000000
SOLAPI_KAKAO_CHANNEL_ID=_xXXXXX
SOLAPI_TEMPLATE_NEW_LISTING=KA01TP_XXXXXXXXXXXXXX
SOLAPI_TEMPLATE_COST_ALERT=KA01TP_XXXXXXXXXXXXXX

# ── 국토부 실거래가 API ─────────────────────────────
MOLIT_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 앱 설정 ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://theoneasset.vercel.app
NEXT_PUBLIC_KAKAO_JAVASCRIPT_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CRON_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
