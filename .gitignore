# =====================================================
# .gitignore - 더원에셋 강남 매물 트래커
# =====================================================

# ── 절대 커밋 금지: 환경변수 (API 키 포함) ──────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
*.env

# ── Next.js ─────────────────────────────────────────
.next/
out/
build/

# ── Node ────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── 크롤링 캐시 ─────────────────────────────────────
.crawler-cache/
*.crawler.json

# ── OS ──────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── 로그 ────────────────────────────────────────────
logs/
*.log

# ── Vercel ──────────────────────────────────────────
.vercel
